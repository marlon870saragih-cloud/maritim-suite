# ============================================================
#  Maritime Suite — contoh environment untuk PRODUKSI
#  Salin ke .env di server, isi nilai sebenarnya. JANGAN commit .env asli.
# ============================================================

# --- Database (PostgreSQL) ---
# URL koneksi utama. Untuk Postgres terkelola (Neon/Supabase) gunakan URL "pooled".
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/maritime_suite?schema=public"
# URL langsung (non-pooled) untuk migrasi/db push. Sama dgn DATABASE_URL bila VPS/Postgres biasa.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/maritime_suite?schema=public"

# --- Autentikasi (NextAuth) ---
# WAJIB kuat & rahasia. Buat dengan: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-secret-acak-yang-kuat"
# Domain produksi Anda (harus persis, dengan https).
NEXTAUTH_URL="https://app.domainanda.com"

# --- Branding publik (opsional) ---
NEXT_PUBLIC_APP_NAME="Maritime Suite"
NEXT_PUBLIC_APP_URL="https://app.domainanda.com"

# --- Asisten AI (OpenRouter) — wajib bila fitur AI dipakai ---
# Ambil di https://openrouter.ai/keys . Ada biaya per pemakaian.
OPENROUTER_API_KEY="sk-or-xxxxxxxxxxxxxxxx"
# Opsional: override model bila katalog OpenRouter berubah.
# OPENROUTER_SPK_MODEL="anthropic/claude-haiku-4.5"
